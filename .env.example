# Copy this file to .env.local and fill in real values.
# Each block is independent — partial setup works (mock fallbacks fill the gaps).

# ---- Anthropic Claude (자서전 생성) ----
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# ---- OpenAI (음성 인식 STT + TTS) ----
# https://platform.openai.com → API Keys
# Whisper: POST /api/transcribe (음성 → 텍스트, language: ko)
# TTS: POST /api/tts (텍스트 → 음성, model: tts-1, voice: nova)
# 없으면 STT는 mock 텍스트 반환, TTS는 브라우저 speechSynthesis fallback
OPENAI_API_KEY=

# ---- Supabase (답변 저장 + slug 발급) ----
# https://supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ---- LemonSqueezy (결제) ----
# https://app.lemonsqueezy.com → Settings → API
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=

# ---- Kakao SDK (카톡 공유) ----
# https://developers.kakao.com → 내 애플리케이션 → JavaScript 키
NEXT_PUBLIC_KAKAO_APP_KEY=

# ---- Resend (이메일 발송) ----
# https://resend.com → API Keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=한권 <noreply@hankwon.com>

# ---- Plausible (분석) ----
# https://plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
